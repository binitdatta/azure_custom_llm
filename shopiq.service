[Unit]
Description=ShopIQ Customer Service Chatbot
After=network.target mysql.service ollama.service

[Service]
Type=simple
User=shopiq
WorkingDirectory=/opt/shopiq-chatbot/app
EnvironmentFile=/opt/shopiq-chatbot/app/.env
ExecStart=/opt/shopiq-chatbot/venv/bin/gunicorn \
    --bind 0.0.0.0:5000 \
    --workers 2 \
    --timeout 120 \
    --access-logfile /var/log/shopiq/access.log \
    --error-logfile  /var/log/shopiq/error.log \
    app:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
