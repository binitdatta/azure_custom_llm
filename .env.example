# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=replace-with-a-long-random-string

# ── MySQL ────────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=shopiq_db
DB_USER=shopiq_app
DB_PASSWORD=shopiq_pass

# ── LLM Server ───────────────────────────────────────────────────────────────
# For Ollama (default):
LLM_BASE_URL=http://localhost:11434/api/chat
LLM_MODEL=llama3.1:8b

# For vLLM (OpenAI-compatible, comment out Ollama lines above):
# LLM_BASE_URL=http://localhost:8000/v1/chat/completions
# LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
